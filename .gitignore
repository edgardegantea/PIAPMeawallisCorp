# ==========================================
# Backend (CodeIgniter 4)
# ==========================================
backend/vendor/
backend/.env

# Ignorar contenido de writable pero mantener la estructura si es necesario
backend/writable/logs/*
backend/writable/cache/*
backend/writable/session/*
backend/writable/debugbar/*
!backend/writable/index.html
!backend/writable/**/index.html

# Subidas de usuarios (normalmente no se van a producción)
backend/writable/uploads/


# ==========================================
# Frontend (Vite / React / Vue)
# ==========================================
frontend/node_modules/
frontend/.env
frontend/.env.*.local

# Forzar a Git a rastrear la carpeta de compilación para despliegues sin CI/CD
!frontend/dist/


# ==========================================
# Sistema / IDEs
# ==========================================
.DS_Store
Thumbs.db
.idea/
.vscode/